###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHAR_SECRET
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=https://votre-domaine.com
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
# Remplir avec vos infos de base de données LWS
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=CHANGE_THIS_JWT_PASSPHRASE
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
# Autoriser votre domaine web et l'app mobile
CORS_ALLOW_ORIGIN='^https?://(localhost|votre-domaine\.com)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

# ===== FRONTEND URL =====
APP_FRONTEND_URL=https://votre-domaine.com

###> symfony/mailer ###
MAILER_DSN=smtp://user:password@smtp.votre-domaine.com:587
###< symfony/mailer ###

###> symfony/mercure-bundle ###
MERCURE_URL=https://votre-domaine.com/.well-known/mercure
MERCURE_PUBLIC_URL=https://votre-domaine.com/.well-known/mercure
MERCURE_JWT_SECRET=CHANGE_THIS_MERCURE_SECRET
###< symfony/mercure-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

# ===== FIREBASE CONFIGURATION =====
FIREBASE_PROJECT_ID=votre-firebase-project-id
FIREBASE_SERVER_KEY=votre-firebase-server-key
FIREBASE_ACCESS_TOKEN=votre-firebase-access-token
