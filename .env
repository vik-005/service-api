###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=CHANGE_ME_TO_A_RANDOM_64CHAR_STRING
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=https://web.motiriispace.com
###< symfony/routing ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME?serverVersion=8.0&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> lexik/jwt-authentication-bundle ###
JWT_SECRET_KEY=%kernel.project_dir%/config/jwt/private.pem
JWT_PUBLIC_KEY=%kernel.project_dir%/config/jwt/public.pem
JWT_PASSPHRASE=CHANGE_ME_JWT_PASSPHRASE
###< lexik/jwt-authentication-bundle ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|web\.motiriispace\.com)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

# ===== FRONTEND URL (pour emails reset password) =====
APP_FRONTEND_URL=https://web.motiriispace.com

###> symfony/mailer ###
MAILER_DSN=null://null
###< symfony/mailer ###

###> symfony/mercure-bundle ###
MERCURE_URL=http://localhost:3000/.well-known/mercure
MERCURE_PUBLIC_URL=http://localhost:3000/.well-known/mercure
MERCURE_JWT_SECRET=CHANGE_ME_MERCURE_SECRET
###< symfony/mercure-bundle ###

###> symfony/messenger ###
MESSENGER_TRANSPORT_DSN=doctrine://default?auto_setup=0
###< symfony/messenger ###

# ===== MOBILE & WEB CONFIGURATION =====
API_BASE_URL=http://10.0.2.2:8000
UPLOADS_BASE_URL=http://10.0.2.2:8000/uploads

# ===== FIREBASE CONFIGURATION =====
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVER_KEY=your_firebase_server_key
FIREBASE_ACCESS_TOKEN=your_firebase_access_token
